# Application Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True
ENVIRONMENT=development

# Database Configuration (REQUIRED)
DATABASE_URL=sqlite:///./sports_betting.db

# Redis Configuration (REQUIRED)
REDIS_URL=redis://localhost:6379/0

# Celery Configuration (REQUIRED)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Sports Data API Keys (Optional - for live odds data)
# Get your free API key from: https://the-odds-api.com/
ODDSAPI_API_KEY=your_odds_api_key_here
THE_ODDS_API_KEY=your_odds_api_key_here

# SportsRadar API Key (Optional - for detailed game data)
# Get your key from: https://developer.sportradar.com/
SPORTSRADAR_API_KEY=your_sportsradar_key_here

# Twitter API Keys (Optional - for sentiment analysis)
TWITTER_BEARER_TOKEN=your_twitter_bearer_token
TWITTER_CONSUMER_KEY=your_twitter_consumer_key
TWITTER_CONSUMER_SECRET=your_twitter_consumer_secret

# Hugging Face (Optional - for advanced sentiment analysis)
HUGGINGFACE_API_KEY=your_huggingface_key
HUGGINGFACE_MODEL=cardiffnlp/twitter-roberta-base-sentiment-latest

# Notion Integration (Optional - for tracking bets in Notion)
NOTION_API_KEY=your_notion_api_key
NOTION_DATABASE_ID=your_notion_database_id

# OpenAI API Key (Optional - for advanced AI analysis)
OPENAI_API_KEY=your_openai_api_key

# Security
SECRET_KEY=your_secret_key_change_this_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
