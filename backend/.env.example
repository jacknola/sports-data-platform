# ============================================================
# sports-data-platform — backend environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ── App Settings ─────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True
ENVIRONMENT=development

# ── Database ─────────────────────────────────────────────────
# Local Docker (default): postgresql://sports_app:sports_password@localhost:5433/sports_data
# Docker Compose service: postgresql://sports_app:sports_password@postgres:5432/sports_data
DATABASE_URL=postgresql://sports_app:sports_password@localhost:5433/sports_data

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Security ─────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_generate_a_real_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Odds / Sports Data APIs ──────────────────────────────────
# The Odds API — https://the-odds-api.com
ODDSAPI_API_KEY=your_paid_key_here
THE_ODDS_API_KEY=your_paid_key_here       # Same as above — both config keys must match
ODDS_API_KEY_FALLBACK=your_starter_key_here  # Starter-tier key; auto-used when paid key hits quota
ODDS_API_IO_KEY=your_key_here

# Sports Game Odds API — https://sportsgameodds.com
SPORTS_GAME_ODDS_API_KEY=your_key_here

# BallDontLie — https://www.balldontlie.io
BALLDONTLIE_API_KEY=your_key_here
BALL_DONT_LIE_API_KEY=your_key_here     # Alias used in some services

# ── Google Sheets ────────────────────────────────────────────
# Service account JSON: download from GCP → IAM → Service Accounts
# Store at: backend/credentials/service-account.json  (gitignored)
GOOGLE_SERVICE_ACCOUNT_PATH=/app/credentials/service-account.json
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# ── Telegram Bot ─────────────────────────────────────────────
# Create bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
TELEGRAM_TIMEZONE=America/New_York

# ── Qdrant Vector Database ───────────────────────────────────
# Local Docker: QDRANT_HOST=localhost, leave QDRANT_API_KEY blank
# Qdrant Cloud: set host to cluster URL, fill in API key
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# ── Supabase (optional — falls back to local PostgreSQL) ─────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here

# ── Slack (optional — webhook for alerts) ───────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# ── AI / ML APIs ─────────────────────────────────────────────
GEMINI_API_KEY=your_key_here
HUGGINGFACE_API_KEY=your_key_here
OPENAI_API_KEY=your_key_here            # Optional

# ── Notion (optional — picks sync) ──────────────────────────
NOTION_API_KEY=your_key_here
NOTION_DATABASE_ID=your_db_id_here

