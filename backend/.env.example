# App Settings
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True
ENVIRONMENT=development

# Database (PostgreSQL for production, SQLite for dev)
DATABASE_URL=postgresql://sports_app:sports_password@postgres:5432/sports_data

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# External APIs
SPORTSRADAR_API_KEY=your_key_here
ODDSAPI_API_KEY=your_key_here
THE_ODDS_API_KEY=your_key_here
BALLDONTLIE_API_KEY=your_key_here
SPORTS_GAME_ODDS_API_KEY=your_key_here

# Twitter API
TWITTER_BEARER_TOKEN=your_token_here
TWITTER_CONSUMER_KEY=your_key_here
TWITTER_CONSUMER_SECRET=your_secret_here

# Hugging Face
HUGGINGFACE_API_KEY=your_key_here
HUGGINGFACE_MODEL=cardiffnlp/twitter-roberta-base-sentiment-latest

# Supabase
SUPABASE_URL=your_url_here
SUPABASE_PUBLISHABLE_KEY=your_key_here
SUPABASE_ANON_KEY=your_key_here

# Notion
NOTION_API_KEY=your_key_here
NOTION_DATABASE_ID=your_db_id_here

# OpenAI (optional, for advanced scraping)
OPENAI_API_KEY=your_key_here

# Gemini (Google AI)
GEMINI_API_KEY=your_key_here

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
TELEGRAM_TIMEZONE=America/New_York

# Qdrant Vector Database
# Local:  QDRANT_HOST=localhost  QDRANT_PORT=6333
# Cloud:  QDRANT_HOST=https://<cluster-id>.<region>.aws.cloud.qdrant.io
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=your_qdrant_api_key_here

# Security
SECRET_KEY=dev_secret_key_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
