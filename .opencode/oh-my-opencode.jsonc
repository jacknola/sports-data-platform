{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/dev/assets/oh-my-opencode.schema.json",

  // ============================================
  // AGENT CONFIGURATION - Use Gemini Models
  // ============================================
  "agents": {
    // Main orchestrator: Use Gemini Pro for Sisyphus
    "sisyphus": {
      "model": "google/gemini-2.5-pro-exp-03-25",
      "temperature": 0.7,
      "ultrawork": { 
        "model": "google/gemini-2.5-pro-exp-03-25", 
        "variant": "max" 
      }
    },

    // Research agents: Flash models are fine
    "librarian": { 
      "model": "google/gemini-2.0-flash",
      "temperature": 0.5
    },
    "explore": { 
      "model": "google/gemini-2.0-flash",
      "temperature": 0.5
    },

    // Architecture consultation: Use Pro for complex reasoning
    "oracle": { 
      "model": "google/gemini-2.5-pro-exp-03-25", 
      "variant": "high",
      "temperature": 0.7
    },

    // Prometheus inherits sisyphus model
    "prometheus": { 
      "prompt_append": "Leverage deep & quick agents heavily, always in parallel. Focus on data quality and validation."
    },

    // Metis for planning consultation
    "metis": {
      "model": "google/gemini-2.5-pro-exp-03-25"
    },

    // Momus for review
    "momus": {
      "model": "google/gemini-2.5-pro-exp-03-25"
    }
  },

  // ============================================
  // CATEGORY CONFIGURATION
  // ============================================
  "categories": {
    // quick — trivial tasks
    "quick": { 
      "model": "google/gemini-2.0-flash",
      "temperature": 0.3
    },

    // unspecified-low — moderate tasks
    "unspecified-low": { 
      "model": "google/gemini-2.0-flash",
      "temperature": 0.5
    },

    // unspecified-high — complex work
    "unspecified-high": { 
      "model": "google/gemini-2.5-pro-exp-03-25",
      "variant": "max",
      "temperature": 0.7
    },

    // writing — docs/prose
    "writing": { 
      "model": "google/gemini-2.5-pro-exp-03-25",
      "temperature": 0.7
    },

    // visual-engineering — UI/UX tasks
    "visual-engineering": { 
      "model": "google/gemini-2.5-pro-exp-03-25",
      "variant": "high",
      "temperature": 0.7
    },

    // deep — autonomous problem-solving
    "deep": {
      "model": "google/gemini-2.5-pro-exp-03-25",
      "variant": "high",
      "temperature": 0.7
    },

    // artistry — creative approaches
    "artistry": {
      "model": "google/gemini-2.5-pro-exp-03-25",
      "variant": "high",
      "temperature": 0.8
    },

    // ultrabrain — hard logic-heavy tasks
    "ultrabrain": {
      "model": "google/gemini-2.5-pro-exp-03-25",
      "variant": "max",
      "temperature": 0.7
    },

    // Custom category for git operations
    "git": {
      "model": "google/gemini-2.0-flash",
      "description": "All git operations",
      "prompt_append": "Focus on atomic commits, clear messages, and safe operations.",
      "temperature": 0.3
    }
  },

  // ============================================
  // BACKGROUND TASK CONFIGURATION
  // ============================================
  "background_task": {
    "defaultConcurrency": 5,
    "staleTimeoutMs": 180000,
    "providerConcurrency": { 
      "google": 10, 
      "anthropic": 3, 
      "openai": 3 
    },
    "modelConcurrency": { 
      "google/gemini-2.5-pro-exp-03-25": 3,
      "google/gemini-2.0-flash": 10
    }
  },

  // ============================================
  // SISYPHUS AGENT CONFIGURATION
  // ============================================
  "sisyphus_agent": {
    "disabled": false,
    "default_builder_enabled": false,
    "planner_enabled": true,
    "replace_plan": true
  },

  // ============================================
  // SISYPHUS TASKS SYSTEM
  // ============================================
  "sisyphus": {
    "tasks": {
      "enabled": true,
      "storage_path": ".sisyphus/tasks",
      "claude_code_compat": false
    }
  },

  // ============================================
  // RUNTIME FALLBACK
  // ============================================
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [400, 429, 503, 529],
    "max_fallback_attempts": 3,
    "cooldown_seconds": 60,
    "timeout_seconds": 30,
    "notify_on_fallback": true
  },

  // ============================================
  // DISABLED FEATURES
  // ============================================
  "disabled_hooks": [],
  "disabled_commands": [],
  "disabled_mcps": [],
  "disabled_skills": [],
  "disabled_agents": [],
  "disabled_categories": [],

  // ============================================
  // EXPERIMENTAL FEATURES
  // ============================================
  "experimental": { 
    "aggressive_truncation": true,
    "task_system": true,
    "dynamic_context_pruning": {
      "enabled": true,
      "notification": "detailed",
      "turn_protection": { 
        "enabled": true, 
        "turns": 3 
      },
      "protected_tools": [
        "task", 
        "todowrite", 
        "todoread", 
        "lsp_rename", 
        "session_read", 
        "session_write", 
        "session_search"
      ],
      "strategies": {
        "deduplication": { "enabled": true },
        "supersede_writes": { 
          "enabled": true, 
          "aggressive": false 
        },
        "purge_errors": { 
          "enabled": true, 
          "turns": 5 
        }
      }
    }
  },

  // ============================================
  // TMUX INTEGRATION
  // ============================================
  "tmux": { 
    "enabled": false,
    "layout": "main-vertical",
    "main_pane_size": 60
  },

  // ============================================
  // HASHLINE EDIT
  // ============================================
  "hashline_edit": true,

  // ============================================
  // GIT MASTER
  // ============================================
  "git_master": { 
    "commit_footer": true, 
    "include_co_authored_by": true 
  }
}
